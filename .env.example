# mr-sentinel local development env vars
# Copy to .env (gitignored) and fill in real values.

# GitLab personal access token. Scopes required: api, read_repository, write_repository
# Issue at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab webhook shared secret (for X-Gitlab-Token verification).
# In production, this lives in Secret Manager: mr-sentinel-gitlab-webhook-secret
# For local dev, pull with:
#   gcloud secrets versions access latest --secret=mr-sentinel-gitlab-webhook-secret --project=aicin-477004
GITLAB_WEBHOOK_SECRET=

# Optional overrides
GITLAB_BASE_URL=https://gitlab.com
GCP_PROJECT_ID=aicin-477004
