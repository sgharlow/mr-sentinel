{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MR Sentinel Rubric",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "category",
        "control_mapping",
        "severity",
        "evaluator_prompt",
        "example_pass",
        "example_fail",
        "suggested_remediation"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)+$"
        },
        "category": {
          "type": "string",
          "enum": ["contract_spec", "quality", "security", "operational"]
        },
        "control_mapping": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error", "blocker"]
        },
        "evaluator_prompt": { "type": "string", "minLength": 10 },
        "example_pass": { "type": "string", "minLength": 1 },
        "example_fail": { "type": "string", "minLength": 1 },
        "suggested_remediation": { "type": "string", "minLength": 1 }
      }
    }
  }
}
